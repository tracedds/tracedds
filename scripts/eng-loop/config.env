# scripts/eng-loop/config.env — tunables for the engineering quality loop.
# Sourced by run-loop.sh and usage-gate.sh. Edit per host, or export the same
# vars before invoking run-loop.sh to override.

# --- Usage gate -------------------------------------------------------------
# Min % of the CLAUDE limit that must REMAIN to use Claude (the preferred engine).
GATE_THRESHOLD="${GATE_THRESHOLD:-50}"
# Which window the gate looks at: week | session | both ("both" = whichever is
# more used; the conservative choice — the loop runs only when BOTH the weekly
# and 5-hour windows have >threshold remaining). Note: the /usage HEADLINE
# percentages are your real account-wide limit state (server-provided); the
# "what's contributing" breakdown below them is local-only/approximate. The gate
# reads only the headline, so it's accurate across devices.
GATE_WINDOW="${GATE_WINDOW:-both}"

# --- Engine selection -------------------------------------------------------
# Prefer Claude when its remaining > GATE_THRESHOLD; otherwise fall back to Codex
# when Codex remaining > CODEX_THRESHOLD; otherwise skip the tick. Codex usage is
# read from its TUI /status panel via tmux (usage-codex.sh) — so the NUC needs
# `tmux` and a logged-in `codex`. Set CODEX_ENABLED=false to use Claude only.
CODEX_ENABLED="${CODEX_ENABLED:-true}"
CODEX_THRESHOLD="${CODEX_THRESHOLD:-25}"
CODEX_BIN="${CODEX_BIN:-codex}"
CODEX_MODEL="${CODEX_MODEL:-}"              # empty = codex default model
# Let usage-codex.sh accept Codex's interactive "Update now" prompt once while
# probing /status, then keep waiting for the TUI to become ready.
CODEX_AUTO_UPDATE="${CODEX_AUTO_UPDATE:-true}"
CODEX_READY_TIMEOUT="${CODEX_READY_TIMEOUT:-180}"

# --- Work selection ---------------------------------------------------------
# Comma-separated GitHub issue labels to drain (OR) before autonomous discovery.
# A labeled issue, once found, sets category="issue" and always takes priority
# over the autonomous CATEGORIES rotation below. Order = priority (the first
# label with an open issue wins). Includes the `eng-loop:<lane>` labels because
# issues are filed under lanes (eng-loop:qa, eng-loop:backend, …), NOT the bare
# `eng-loop` label — draining only the bare label silently picks up nothing and
# the loop falls through to autonomous clustering on every tick.
LOOP_LABELS="${LOOP_LABELS:-eng-loop,qa,eng-loop:qa,eng-loop:qa-design,eng-loop:backend,eng-loop:architecture}"
# Repo to operate on (owner/name).
LOOP_REPO="${LOOP_REPO:-tracedds/tracedds}"

# Autonomous work categories, round-robined across ticks (one playbook per tick,
# see playbooks/). A labeled issue, if present, always takes priority over this.
#   qa-design  — UI QA / design / bug-fixing (screenshot evidence)
#   clustering — catalog over/under-clustering (dry-run metrics-diff evidence)
#   ocr        — lot/expiry label reading (parser-accuracy diff; sources real labels)
#   pricing    — price/vendor coverage vs Net32 (only if PRICING_ENABLED; see below)
CATEGORIES="${CATEGORIES:-qa-design,clustering,ocr}"

# Backpressure: max open loop PRs allowed PER CATEGORY before that category is
# skipped for the tick (counted via the `eng-loop:<category>` label). Keeps any
# one lane from piling up unreviewed/conflicting PRs. The loop idles a tick only
# when every enabled category is at its cap.
MAX_OPEN_PER_CATEGORY="${MAX_OPEN_PER_CATEGORY:-2}"

# --- Paths ------------------------------------------------------------------
# Where worktrees, logs, locks and the loop's own checkout live.
LOOP_HOME="${LOOP_HOME:-$HOME/eng-loop}"
# A git checkout dedicated to the loop (kept current via `git pull`). Keep this
# SEPARATE from /opt/medmkp so the loop never races Airflow's deploy checkout.
REPO_DIR="${REPO_DIR:-$LOOP_HOME/checkout}"

# --- App under test ---------------------------------------------------------
# Backend the worktree's `next dev` talks to: prod | local
# prod = read-only against live data (matches the team's QA workflow). The loop
# MUST NOT perform destructive mutations against prod (enforced in loop-prompt).
BACKEND_TARGET="${BACKEND_TARGET:-prod}"

# --- Data-quality backend access (clustering / pricing playbooks) -----------
# Read-only prod Postgres URL. Needed by the clustering dry-run and pricing
# queries. Leave empty to auto-skip those categories. KEEP THIS IN THE SECRETS
# FILE, not here (it's a credential). The NUC already has it for its match DAG.
# `DB_URL` is also accepted as an alias (mapped in run-loop.sh after secrets load).
LOOP_DATABASE_URL="${LOOP_DATABASE_URL:-}"

# Net32 price-comparison playbook. Off by default: it needs the NUC harvester
# sidecar running and is experimental. Set true once the sidecar is up.
PRICING_ENABLED="${PRICING_ENABLED:-false}"
NET32_HARVESTER_URL="${NET32_HARVESTER_URL:-http://127.0.0.1:8791}"

# --- Claude headless --------------------------------------------------------
CLAUDE_BIN="${CLAUDE_BIN:-claude}"
CLAUDE_MODEL="${CLAUDE_MODEL:-}"            # empty = account default
# Hard ceiling (seconds) on a single run so a stuck run can't burn the budget.
RUN_TIMEOUT="${RUN_TIMEOUT:-3600}"

# --- Optional secrets -------------------------------------------------------
# If present, sourced for test creds used to log into gated /app pages, e.g.
#   export LOOP_TEST_EMAIL=withloc@local.test
#   export LOOP_TEST_PASSWORD=...
# Keep this file OUT of version control.
SECRETS_FILE="${SECRETS_FILE:-$HOME/.eng-loop.secrets}"
