# scripts/eng-loop/secrets.env — UNTRACKED secrets for the eng-loop (gitignored).
# Copy to secrets.env on the host that runs the loop and fill in. config.env
# sources this automatically if present.

# Slack or Discord incoming-webhook URL for health alerts (health.sh auto-detects
# which from the URL). Leave unset to disable webhook alerts.
# ALERT_WEBHOOK_URL="https://hooks.slack.com/services/XXX/YYY/ZZZ"
# ALERT_WEBHOOK_URL="https://discord.com/api/webhooks/XXX/YYY"
