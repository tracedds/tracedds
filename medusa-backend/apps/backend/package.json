{
  "name": "@dtc/backend",
  "version": "0.0.1",
  "description": "A starter for Medusa projects.",
  "author": "Medusa (https://medusajs.com)",
  "license": "MIT",
  "keywords": [
    "sqlite",
    "postgres",
    "typescript",
    "ecommerce",
    "headless",
    "medusa"
  ],
  "scripts": {
    "build": "medusa build",
    "start": "sh ./scripts/start-render.sh",
    "start:render": "npm run start",
    "dev": "medusa develop",
    "db:generate": "medusa db:generate medmkp",
    "db:migrate": "medusa db:migrate",
    "seed:catalog-sample": "ts-node ./src/scripts/seed-catalog-sample.ts",
    "supplier:vet": "ts-node ./src/scripts/vet-dental-suppliers.ts",
    "supplier:seed-usable": "medusa exec ./src/scripts/seed-usable-dental-suppliers.ts",
    "supplier:import-csv": "medusa exec ./src/scripts/import-supplier-catalog-csv.ts",
    "supplier:ingest": "ts-node ./src/scripts/run-supplier-ingestion.ts",
    "supplier:ingest:db": "medusa exec ./src/scripts/ingest-supplier-catalogs.ts --",
    "marketplace:ingest": "medusa exec ./src/scripts/ingest-marketplace-catalog.ts --",
    "henryschein:ingest": "medusa exec ./src/scripts/ingest-henryschein-catalog.ts --",
    "patterson:ingest": "medusa exec ./src/scripts/ingest-patterson-catalog.ts --",
    "darby:ingest": "medusa exec ./src/scripts/ingest-darby-catalog.ts --",
    "supplier:estimate-shipping": "medusa exec ./src/scripts/estimate-supplier-shipping.ts --",
    "supplier:seed-shipping-policies": "medusa exec ./src/scripts/seed-supplier-shipping-policies.ts --",
    "marketplace:status": "medusa exec ./src/scripts/marketplace-catalog-status.ts --",
    "pack:backfill": "medusa exec ./src/scripts/backfill-pack-normalization.ts --",
    "catalog:dedupe": "medusa exec ./src/scripts/dedupe-supplier-products.ts --",
    "catalog:purge-soft-deleted": "medusa exec ./src/scripts/purge-soft-deleted-catalog.ts --",
    "catalog:clean-names": "medusa exec ./src/scripts/clean-product-names.ts --",
    "catalog:refresh-read-models": "ts-node ./src/scripts/refresh-catalog-read-models.ts",
    "catalog:refresh-match-index": "ts-node ./src/scripts/refresh-match-index.ts",
    "products:match": "ts-node ./src/scripts/match-canonical-products.ts",
    "products:propose-axes": "ts-node ./src/scripts/propose-variant-axes.ts",
    "gtin:ingest-gudid": "ts-node ./src/scripts/ingest-gudid-gtin-reference.ts",
    "gtin:enrich-barcodes": "ts-node ./src/scripts/enrich-barcodes-from-gudid.ts",
    "admin:create": "medusa user -e admin@medmkp.local -p medmkp-admin",
    "test:integration:http": "TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:integration:modules": "TEST_TYPE=integration:modules NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:unit": "TEST_TYPE=unit NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --forceExit"
  },
  "dependencies": {
    "@medusajs/admin-sdk": "2.15.5",
    "@medusajs/admin-shared": "2.15.5",
    "@medusajs/caching": "2.15.5",
    "@medusajs/cli": "2.15.5",
    "@medusajs/dashboard": "2.15.5",
    "@medusajs/draft-order": "2.15.5",
    "@medusajs/framework": "2.15.5",
    "@medusajs/medusa": "2.15.5",
    "@tanstack/react-query": "5.64.2",
    "react-router-dom": "6.30.3",
    "react-i18next": "13.5.0",
    "@medusajs/ui": "4.1.15",
    "zod": "4.2.0"
  },
  "devDependencies": {
    "@medusajs/test-utils": "2.15.5",
    "@swc/core": "^1.7.28",
    "@swc/jest": "^0.2.36",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.12.11",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.2.25",
    "jest": "^29.7.0",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "vite": "^5.4.14",
    "yalc": "^1.0.0-pre.53"
  },
  "engines": {
    "node": "20.x"
  },
  "packageManager": "npm@11.12.1"
}
