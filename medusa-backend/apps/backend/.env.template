# Environment layout (loaded by Medusa's loadEnv):
#   .env             -> local development (always loaded; keep it pointing at the
#                       local docker-compose database, never at a remote one)
#   .env.production  -> remote/Render database; only loaded when NODE_ENV=production.
#                       Run deliberate prod operations as: NODE_ENV=production npm run <script>
#   .env.template    -> this file; the only env file tracked by git
#
# Guarded scripts (seed:catalog-sample, supplier:seed-usable,
# supplier:import-csv, supplier:ingest:db, products:match --commit) refuse to
# run against a non-local DATABASE_URL unless ALLOW_REMOTE_DB_DESTRUCTIVE=true.
# To seed a realistic local catalog, pull a sample from a source database
# (the source connection is opened read-only):
#   SOURCE_DATABASE_URL=postgres://... npm run seed:catalog-sample -- --per-supplier=100

MEDUSA_ADMIN_ONBOARDING_TYPE=default
STORE_CORS=http://localhost:8000,https://docs.medusajs.com
ADMIN_CORS=http://localhost:5173,http://localhost:9000,https://docs.medusajs.com
AUTH_CORS=http://localhost:5173,http://localhost:9000,https://docs.medusajs.com
REDIS_URL=redis://localhost:6379
JWT_SECRET=supersecret
COOKIE_SECRET=supersecret
# Web app base URL. Used by the auth.password_reset subscriber to build the
# password reset link that is emailed (or, in dev, logged) to customers.
MEDMKP_FRONTEND_URL=http://localhost:3000
DATABASE_URL=postgres://medmkp:medmkp@127.0.0.1:55432/medmkp_medusa
DB_NAME=medmkp_medusa
DB_SSL=false
# Optional pool tuning for Medusa startup on Render:
# DB_POOL_MIN=1
# DB_POOL_MAX=20
# DB_POOL_ACQUIRE_TIMEOUT_MS=60000
# DB_POOL_IDLE_TIMEOUT_MS=30000
# DB_POOL_CREATE_RETRY_INTERVAL_MS=200
