{
  "name": "medusa-backend",
  "private": false,
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "npm run build --prefix apps/backend",
    "start": "npm run start --prefix apps/backend",
    "lint": "turbo lint",
    "test": "turbo test",
    "infra:up": "docker compose -f ../docker-compose.yml up -d",
    "infra:down": "docker compose -f ../docker-compose.yml down",
    "backend:db:generate": "npm run db:generate --workspace=@dtc/backend",
    "backend:db:migrate": "npm run db:migrate --prefix apps/backend",
    "backend:seed:demo": "npm run seed:demo --prefix apps/backend",
    "backend:seed": "npm run backend:seed:demo",
    "backend:admin:create": "npm run admin:create --prefix apps/backend",
    "backend:dev": "turbo dev --filter=@dtc/backend",
    "dev:medusa": "npm run backend:dev",
    "db:generate": "npm run backend:db:generate",
    "db:migrate": "npm run backend:db:migrate",
    "seed:demo": "npm run backend:seed:demo",
    "seed:medmkp": "npm run seed:demo",
    "admin:create": "npm run backend:admin:create",
    "storefront:dev": "turbo dev --filter=@dtc/storefront"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.0.5",
      "@types/react-dom": "19.0.5"
    }
  },
  "devDependencies": {
    "turbo": "^2.0.14",
    "prettier": "^3.2.5"
  },
  "workspaces": [
    "apps/**",
    "!apps/backend/.medusa/**"
  ],
  "overrides": {
    "ajv": "^8.0.0"
  }
}
